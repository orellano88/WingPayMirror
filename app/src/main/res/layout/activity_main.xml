<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- CABECERA STARK RED -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FF0000"
        android:padding="12dp"
        android:elevation="4dp">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WING COMMAND v40.0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELEGRAM BRIDGE ACTIVE"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/bg_whatsapp_bubble"
                android:backgroundTint="#33000000"
                android:paddingHorizontal="6dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#FFFFFF"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- PANEL DE CONFIGURACIÓN TELEGRAM (OCULTO POR DEFECTO) -->
    <LinearLayout
        android:id="@+id/layoutSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="2dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuración de Telegram"
            android:textStyle="bold"
            android:textColor="#FF0000"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bot Token (de @BotFather)"
            android:textSize="12sp"/>

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Chat ID (de @userinfobot)"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GUARDAR ENLACE NEURONAL"
            android:backgroundTint="#FF0000"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- LISTA DE CHAT -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutSettings"
        android:layout_above="@+id/bottom_bar"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- BARRA DE MENSAJES -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F0F2F5"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            android:tint="#666666"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_whatsapp_bubble"
            android:backgroundTint="#FFFFFF"
            android:hint="Escribe un mensaje..."
            android:textColor="#000000"
            android:padding="12dp"
            android:layout_marginHorizontal="4dp"
            android:textSize="14sp"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/ic_whatsapp_red"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:padding="10dp"/>
    </LinearLayout>

    <!-- OVERLAY DE ALERTA -->
    <View
        android:id="@+id/alert_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88FF0000"
        android:visibility="gone"/>

</RelativeLayout>
