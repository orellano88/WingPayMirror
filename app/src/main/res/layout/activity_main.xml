<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- CABECERA STARK CON INDICADOR DE ROL -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FF0000"
        android:padding="12dp"
        android:elevation="4dp">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WING COMMAND"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODO MAESTRO"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/bg_whatsapp_bubble"
                android:backgroundTint="#33000000"
                android:paddingHorizontal="6dp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPanic"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:tint="#FFFFFF"
            android:layout_centerVertical="true"/>
            
        <ImageButton
            android:id="@+id/btnQR"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_toStartOf="@id/btnPanic"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#FFFFFF"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- FOOTER INVERSIONES WING -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:gravity="center"
        android:elevation="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INVERSIONES WING — SISTEMA DE ESPEJO NEURONAL"
            android:textColor="#99000000"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <!-- BARRA DE MENSAJES -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/footer"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F0F2F5"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_whatsapp_bubble"
            android:backgroundTint="#FFFFFF"
            android:hint="Escribe un mensaje..."
            android:textColorHint="#99000000"
            android:textColor="#000000"
            android:padding="12dp"
            android:layout_marginHorizontal="8dp"
            android:maxLines="4"
            android:textSize="14sp"
            android:elevation="2dp"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/ic_whatsapp_red"
            android:src="@android:drawable/ic_menu_send"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:tint="#FFFFFF"
            android:elevation="4dp"/>

    </LinearLayout>

    <!-- LISTA DE CHAT -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottom_bar"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- OVERLAY DE ALERTA -->
    <View
        android:id="@+id/alert_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88FF0000"
        android:visibility="gone"/>

</RelativeLayout>
