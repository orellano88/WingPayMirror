<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <!-- CABECERA STARK CON BOTON DE PANICO -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FF0000"
        android:padding="12dp"
        android:elevation="8dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WING COMMAND CENTER"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_centerVertical="true"/>

        <ImageButton
            android:id="@+id/btnPanic"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/ic_whatsapp_red"
            android:backgroundTint="#FFFFFF"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:tint="#FF0000"
            android:layout_centerVertical="true"/>
            
        <View
            android:id="@+id/heartbeat_indicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@android:drawable/presence_online"
            android:layout_toStartOf="@id/btnPanic"
            android:layout_marginEnd="10dp"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- BARRA DE MENSAJES ESTILO WHATSAPP -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#101010"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#FFFFFF"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_whatsapp_bubble"
            android:hint="Escribe un mensaje..."
            android:textColorHint="#66FFFFFF"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginHorizontal="8dp"
            android:maxLines="4"
            android:textSize="14sp"/>

        <ImageButton
            android:id="@+id/btnAudio"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFFFFF"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/ic_whatsapp_red"
            android:src="@android:drawable/ic_menu_send"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottom_bar"
        android:padding="8dp"
        android:clipToPadding="false"/>

</RelativeLayout>
